# ─── Block 5: Impressum & Email-Footer ──────────────────────────
# Diese Werte in Vercel Environment-Variables setzen, dann Redeploy.
# Bis zum Setzen nutzen Pages + Footer Platzhalter wie "[Firmenname – zu setzen]".

# Firma (Pflicht)
COMPANY_NAME=
COMPANY_LEGAL_FORM=              # z.B. "GmbH" | "UG (haftungsbeschränkt)" | "LLC" — leer wenn Einzelunternehmen

# Adresse (Pflicht)
COMPANY_STREET=                  # z.B. "Musterstraße 12"
COMPANY_POSTAL_CODE=             # z.B. "10115"
COMPANY_CITY=                    # z.B. "Berlin"
COMPANY_COUNTRY=Deutschland

# Vertretung (Pflicht bei GmbH/UG/AG, sonst Inhaber-Name)
COMPANY_REPRESENTATIVE=          # z.B. "Lano Aziz"

# Handelsregister (nur bei GmbH/UG/AG)
COMPANY_HANDELSREGISTER=         # z.B. "HRB 12345"
COMPANY_AMTSGERICHT=             # z.B. "Amtsgericht Berlin-Charlottenburg"

# USt-ID (nur wenn vorhanden)
COMPANY_UST_ID=                  # z.B. "DE123456789"

# Kontakt
COMPANY_CONTACT_EMAIL=hello@deine-treuekarte.de
COMPANY_PHONE=                   # optional

# Datenschutzbeauftragter (optional — nur wenn nicht = Geschäftsführer)
COMPANY_DPO_NAME=
COMPANY_DPO_EMAIL=               # Fallback: COMPANY_CONTACT_EMAIL

# ─── Existierende Vars (Referenz) ───────────────────────────────
# NEXT_PUBLIC_DOWNLOAD_BASE_URL=https://deine-treuekarte.de
# NEXT_PUBLIC_BASE_URL=https://autrich.vercel.app
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# ANTHROPIC_API_KEY=
# (weitere je nach Setup)
